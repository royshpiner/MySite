{
  "name": "mysite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:chat",
    "build:chat": "esbuild src/site-chat.tsx --bundle --format=iife --outfile=static/js/site-chat.js --jsx=automatic --minify",
    "check": "tsc --noEmit"
